model Earnings {
  id          String   @id @default(uuid())
  eventId     String
  creatorId   String
  amount      Float
  platformFee Float
  creatorEarn Float
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
